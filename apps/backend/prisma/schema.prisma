generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Initiative {
  id          String   @id @default(uuid())
  category    String?
  title       String
  description String
  status      String
  link        String?
  imageUrl    String?
  metrics     String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FieldLog {
  id          String   @id @default(uuid())
  type        String
  category    String?
  title       String
  content     String
  imageUrls   String
  youtubeId   String?
  metrics     String?
  eventDate   DateTime
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AboutUs {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RootsEntry {
  id          String   @id @default(uuid())
  section     String   @default("build")
  order       Int      @default(0)
  title       String   @default("Built with our hands, ground to roof.")
  description String   @default("We don't design solutions on paper — we execute them. This is the permanent archive of our community school's full construction timeline — from first stone to final beam.")
  videoTitle  String   @default("School build, A to Z")
  youtubeId   String?
  imageUrls   String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([section])
}

model Donation {
  id        String   @id @default(uuid())
  amount    Float
  donorName String
  date      DateTime @default(now())
  projectId String?
}
