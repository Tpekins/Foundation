{
  "buildCommand": "yarn install && yarn workspace frontend build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://foundation-backend-git-dev-tpekins-projects.vercel.app/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
