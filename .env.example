# DATABASE_URL — PostgreSQL connection string for Prisma.
# Example (Neon): postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/tianipekins"

# ADMIN_API_KEY — Secret key for admin write endpoints (update/delete content).
# Set a strong random value in production. Pass as X-API-Key header.
ADMIN_API_KEY="change-me-to-a-random-secret"
